{
  "name": "derbyapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:generate-sql": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script 2>/dev/null > schema.sql"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@vercel/blob": "^1.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "next": "16.2.2",
    "next-intl": "^4.9.1",
    "prisma": "^7.6.0",
    "qrcode.react": "^4.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
}
