generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Team {
  id          String   @id @default(cuid())
  name        String
  shortName   String?
  logoUrl     String?
  color       String?
  descriptionNl String?
  descriptionEn String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  players     Player[]
  matchesA    Match[]  @relation("TeamA")
  matchesB    Match[]  @relation("TeamB")
}

model Player {
  id          String    @id @default(cuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  derbyName   String
  number      String
  headshotUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  mvpVotes    MvpVote[]
}

model Match {
  id        String    @id @default(cuid())
  startsAt  DateTime
  poule     String?
  teamAId   String
  teamBId   String
  teamA     Team      @relation("TeamA", fields: [teamAId], references: [id])
  teamB     Team      @relation("TeamB", fields: [teamBId], references: [id])
  scoreA    Int?
  scoreB    Int?
  status    String    @default("scheduled")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  mvpVotes  MvpVote[]
}

model Photo {
  id           String   @id @default(cuid())
  url          String
  thumbUrl     String?
  uploaderName String?
  caption      String?
  createdAt    DateTime @default(now())
}

model MvpVote {
  id        String   @id @default(cuid())
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  voterHash String
  createdAt DateTime @default(now())

  @@unique([voterHash, matchId])
}

model BingoPrompt {
  id       String  @id @default(cuid())
  text     String
  category String?
  active   Boolean @default(true)
}

model HouseRule {
  id    String @id @default(cuid())
  order Int    @default(0)
  title String
  body  String
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// External registration links shown on /aanmelden. Bilingual label/description
// (EN falls back to NL when empty). Hidden by default (visible=false) so a link
// can be prepared ahead of time and switched on manually.
model RegistrationLink {
  id            String   @id @default(cuid())
  order         Int      @default(0)
  url           String
  labelNl       String
  labelEn       String?
  descriptionNl String?
  descriptionEn String?
  visible       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Per-page visibility toggle. `key` is a page key from src/lib/pages.ts
// (e.g. "teams"). A missing row means visible — only hidden pages need a row
// with visible=false. Nav items are filtered and the routes return notFound()
// when hidden.
model PageVisibility {
  key       String   @id
  visible   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// History of push notifications sent from /admin/push. Written by sendToAll()
// after each send so organisers can see what went out and how it landed.
model SentNotification {
  id           String   @id @default(cuid())
  title        String
  body         String
  url          String?
  sentCount    Int      @default(0)
  removedCount Int      @default(0)
  failedCount  Int      @default(0)
  errors       String?  // newline-joined failure summaries, null when none
  createdAt    DateTime @default(now())
}

// Editable text layer over next-intl. `key` is a dotted path into the message
// tree (e.g. "Home.countdownLabel"). Absent keys fall back to messages/*.json.
model MessageOverride {
  id        String   @id @default(cuid())
  locale    String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([locale, key])
}
